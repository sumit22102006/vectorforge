PORT=5000
NODE_ENV=development

# Ollama Endpoint Configuration
OLLAMA_URL=http://localhost:11434/api/chat

# Ollama API Key (if required by custom local endpoints or remote proxy gateways)
OLLAMA_API_KEY=

# Ollama Model Version to call (defaults to Llama 3.2 3B parameters)
OLLAMA_MODEL=llama3.2:3b
